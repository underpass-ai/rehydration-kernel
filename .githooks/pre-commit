#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "${ROOT_DIR}"

if [[ "${SKIP_CLIPPY_HOOK:-}" == "1" ]]; then
  echo "pre-commit: skipping clippy because SKIP_CLIPPY_HOOK=1"
  exit 0
fi

echo "pre-commit: running cargo clippy --workspace --all-targets --locked -- -D warnings"
cargo clippy --workspace --all-targets --locked -- -D warnings
