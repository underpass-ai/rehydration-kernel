#!/usr/bin/env bash

set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

cd "${ROOT_DIR}"

if [[ "${SKIP_NEO4J_SCHEMA_HOOK:-}" == "1" ]]; then
  echo "pre-commit: skipping Neo4j schema migration checks because SKIP_NEO4J_SCHEMA_HOOK=1"
else
  echo "pre-commit: running Neo4j schema migration fast checks"
  cargo test -p rehydration-adapter-neo4j --locked schema_migration
  cargo check -p rehydration-server --bin rehydration-neo4j-migrate --locked
fi

if [[ "${SKIP_CLIPPY_HOOK:-}" == "1" ]]; then
  echo "pre-commit: skipping clippy because SKIP_CLIPPY_HOOK=1"
else
  echo "pre-commit: running cargo clippy --workspace --all-targets --locked -- -D warnings"
  cargo clippy --workspace --all-targets --locked -- -D warnings
fi

if [[ "${SKIP_COVERAGE_HOOK:-}" == "1" ]]; then
  echo "pre-commit: skipping local coverage because SKIP_COVERAGE_HOOK=1"
  exit 0
fi

if ! cargo llvm-cov --version >/dev/null 2>&1; then
  echo "pre-commit: cargo-llvm-cov is required for local coverage"
  echo "pre-commit: install it with: cargo install cargo-llvm-cov"
  exit 1
fi

COVERAGE_HOOK_MIN_LINES="${COVERAGE_HOOK_MIN_LINES:-80}"

echo "pre-commit: running production kernel coverage with minimum ${COVERAGE_HOOK_MIN_LINES}% line coverage"
COVERAGE_MIN_LINES="${COVERAGE_HOOK_MIN_LINES}" bash scripts/ci/rust-coverage.sh
