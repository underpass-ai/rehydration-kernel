{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://underpass.ai/schemas/rehydration-kernel/v1beta1/kernel-memory-protocol.schema.json",
  "title": "KernelMemoryProtocol",
  "description": "Transport-neutral Kernel Memory Protocol contract fixtures for ingest, write-memory, wake, ask, goto, near, rewind, forward, trace, and inspect moves.",
  "oneOf": [
    {
      "$ref": "#/$defs/ingest_request"
    },
    {
      "$ref": "#/$defs/ingest_response"
    },
    {
      "$ref": "#/$defs/write_memory_request"
    },
    {
      "$ref": "#/$defs/write_memory_response"
    },
    {
      "$ref": "#/$defs/wake_request"
    },
    {
      "$ref": "#/$defs/wake_response"
    },
    {
      "$ref": "#/$defs/ask_request"
    },
    {
      "$ref": "#/$defs/ask_response"
    },
    {
      "$ref": "#/$defs/goto_request"
    },
    {
      "$ref": "#/$defs/goto_response"
    },
    {
      "$ref": "#/$defs/near_request"
    },
    {
      "$ref": "#/$defs/near_response"
    },
    {
      "$ref": "#/$defs/rewind_request"
    },
    {
      "$ref": "#/$defs/rewind_response"
    },
    {
      "$ref": "#/$defs/forward_request"
    },
    {
      "$ref": "#/$defs/forward_response"
    },
    {
      "$ref": "#/$defs/trace_request"
    },
    {
      "$ref": "#/$defs/trace_response"
    },
    {
      "$ref": "#/$defs/inspect_request"
    },
    {
      "$ref": "#/$defs/inspect_response"
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "semantic_class": {
      "type": "string",
      "enum": [
        "structural",
        "causal",
        "motivational",
        "procedural",
        "evidential",
        "constraint"
      ]
    },
    "answer_policy": {
      "type": "string",
      "description": "Answer policy selector. Current live gRPC/MCP mode is deterministic evidence-only: show_conflicts does not run conflict detection yet, and best_effort does not generate fallback text.",
      "enum": [
        "evidence_or_unknown",
        "show_conflicts",
        "best_effort"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_agent",
        "observed_at"
      ],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "projection",
            "derived"
          ]
        },
        "source_agent": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_at": {
          "$ref": "#/$defs/date_time"
        },
        "correlation_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "causation_id": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "temporal_coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "scope_id"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "occurred_at": {
          "$ref": "#/$defs/date_time"
        },
        "observed_at": {
          "$ref": "#/$defs/date_time"
        },
        "ingested_at": {
          "$ref": "#/$defs/date_time"
        },
        "valid_from": {
          "$ref": "#/$defs/date_time"
        },
        "valid_until": {
          "$ref": "#/$defs/date_time"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "resolved_temporal_coordinate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dimension": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "occurred_at": {
          "$ref": "#/$defs/date_time"
        },
        "observed_at": {
          "$ref": "#/$defs/date_time"
        },
        "ingested_at": {
          "$ref": "#/$defs/date_time"
        },
        "valid_from": {
          "$ref": "#/$defs/date_time"
        },
        "valid_until": {
          "$ref": "#/$defs/date_time"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "rank": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      },
      "anyOf": [
        {
          "required": [
            "occurred_at"
          ]
        },
        {
          "required": [
            "observed_at"
          ]
        },
        {
          "required": [
            "ingested_at"
          ]
        },
        {
          "required": [
            "valid_from"
          ]
        },
        {
          "required": [
            "valid_until"
          ]
        },
        {
          "required": [
            "sequence"
          ]
        },
        {
          "required": [
            "rank"
          ]
        },
        {
          "required": [
            "dimension",
            "scope_id"
          ]
        }
      ]
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "text",
        "coordinates"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/temporal_coordinate"
          }
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "rel",
        "class"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rel": {
          "$ref": "#/$defs/non_empty_string"
        },
        "class": {
          "$ref": "#/$defs/semantic_class"
        },
        "why": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence": {
          "$ref": "#/$defs/non_empty_string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "class": {
                "const": "structural"
              }
            },
            "required": [
              "class"
            ]
          },
          "then": true,
          "else": {
            "required": [
              "confidence"
            ],
            "anyOf": [
              {
                "required": [
                  "why"
                ]
              },
              {
                "required": [
                  "evidence"
                ]
              }
            ]
          }
        }
      ]
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source": {
          "$ref": "#/$defs/non_empty_string"
        },
        "time": {
          "$ref": "#/$defs/date_time"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimensions",
        "entries"
      ],
      "properties": {
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dimension"
          }
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entry"
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_item"
          }
        }
      }
    },
    "accepted_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entries",
        "relations",
        "evidence"
      ],
      "properties": {
        "entries": {
          "type": "integer",
          "minimum": 0
        },
        "relations": {
          "type": "integer",
          "minimum": 0
        },
        "evidence": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "warning_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tokens": {
          "type": "integer",
          "minimum": 1
        },
        "detail": {
          "type": "string",
          "enum": [
            "compact",
            "balanced",
            "full"
          ]
        },
        "depth": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "dimension_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "all",
            "only",
            "except"
          ]
        },
        "include": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "scope": {
          "type": "string",
          "enum": [
            "current_about",
            "abouts",
            "all_abouts"
          ]
        },
        "abouts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "scope_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          },
          "description": "Exact dimension scope ids to include. Values may be local dimension ids or namespaced about:<about>:dimension:<dimension_id> ids."
        }
      }
    },
    "temporal_cursor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "time": {
          "$ref": "#/$defs/date_time"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        }
      },
      "oneOf": [
        {
          "required": [
            "ref"
          ]
        },
        {
          "required": [
            "time"
          ]
        },
        {
          "required": [
            "sequence"
          ]
        }
      ]
    },
    "temporal_limit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "integer",
          "minimum": 1
        },
        "tokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "temporal_window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before_entries": {
          "type": "integer",
          "minimum": 0
        },
        "after_entries": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "temporal_include": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "type": "boolean"
        },
        "relations": {
          "type": "boolean"
        },
        "raw_refs": {
          "type": "boolean",
          "description": "Return typed raw audit refs for selected temporal entries."
        }
      }
    },
    "temporal_move_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "from"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "from": {
          "$ref": "#/$defs/temporal_cursor"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        },
        "limit": {
          "$ref": "#/$defs/temporal_limit"
        },
        "include": {
          "$ref": "#/$defs/temporal_include"
        },
        "budget": {
          "$ref": "#/$defs/budget"
        }
      }
    },
    "temporal_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "kind",
        "text",
        "coordinates"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/temporal_coordinate"
          }
        }
      }
    },
    "raw_memory_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "kind",
        "text",
        "coordinates",
        "detail",
        "content_hash",
        "revision"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/temporal_coordinate"
          }
        },
        "detail": {
          "type": "string"
        },
        "content_hash": {
          "type": "string"
        },
        "revision": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "temporal_move_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "temporal",
        "coverage",
        "entries",
        "proof",
        "warnings",
        "raw_refs"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "temporal": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "direction",
            "requested",
            "resolved"
          ],
          "properties": {
            "direction": {
              "type": "string",
              "enum": [
                "goto",
                "near",
                "rewind",
                "forward"
              ]
            },
            "requested": {
              "$ref": "#/$defs/temporal_cursor"
            },
            "resolved": {
              "$ref": "#/$defs/resolved_temporal_coordinate"
            }
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requested",
            "included",
            "missing"
          ],
          "properties": {
            "requested": {
              "$ref": "#/$defs/dimension_selection"
            },
            "included": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "missing": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/temporal_entry"
          }
        },
        "proof": {
          "$ref": "#/$defs/proof"
        },
        "warnings": {
          "$ref": "#/$defs/warning_list"
        },
        "raw_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/raw_memory_ref"
          }
        }
      }
    },
    "goto_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "at"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "at": {
          "$ref": "#/$defs/temporal_cursor"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        },
        "include": {
          "$ref": "#/$defs/temporal_include"
        },
        "budget": {
          "$ref": "#/$defs/budget"
        }
      }
    },
    "goto_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "near_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "around"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "around": {
          "$ref": "#/$defs/temporal_cursor"
        },
        "window": {
          "$ref": "#/$defs/temporal_window"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        },
        "include": {
          "$ref": "#/$defs/temporal_include"
        },
        "budget": {
          "$ref": "#/$defs/budget"
        }
      }
    },
    "near_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "rewind_request": {
      "$ref": "#/$defs/temporal_move_request"
    },
    "rewind_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "forward_request": {
      "$ref": "#/$defs/temporal_move_request"
    },
    "forward_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence"
      ],
      "properties": {
        "path": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_item"
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "writer_intent": {
      "type": "string",
      "enum": [
        "record_turn",
        "record_observation",
        "record_decision",
        "record_feedback",
        "record_delta"
      ]
    },
    "writer_node_kind": {
      "type": "string",
      "enum": [
        "turn",
        "observation",
        "decision",
        "feedback",
        "semantic_delta",
        "constraint",
        "preference",
        "derived_value",
        "error_path",
        "success_path"
      ]
    },
    "writer_relation_name": {
      "type": "string",
      "enum": [
        "follows",
        "answers",
        "uses_background",
        "depends_on",
        "chosen_because",
        "semantic_delta_from",
        "updates_state",
        "supports",
        "supersedes",
        "contradicts",
        "satisfies_constraint",
        "violates_constraint",
        "contributes_to",
        "excluded_from",
        "checked_against",
        "derived_from",
        "confirms_selection",
        "contains",
        "member_of",
        "scoped_to"
      ]
    },
    "write_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "process"
      ],
      "properties": {
        "task": {
          "$ref": "#/$defs/non_empty_string"
        },
        "process": {
          "$ref": "#/$defs/non_empty_string"
        },
        "episode": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "current_write_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "summary"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/writer_node_kind"
        },
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "semantic_delta_write": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "why",
        "evidence"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "from": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to": {
          "$ref": "#/$defs/non_empty_string"
        },
        "why": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "write_link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "rel",
        "class"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rel": {
