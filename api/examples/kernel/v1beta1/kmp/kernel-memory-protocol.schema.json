{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://underpass.ai/schemas/rehydration-kernel/v1beta1/kernel-memory-protocol.schema.json",
  "title": "KernelMemoryProtocol",
  "description": "Transport-neutral Kernel Memory Protocol draft contract for ingest, wake, ask, rewind, forward, trace, and inspect moves.",
  "oneOf": [
    {
      "$ref": "#/$defs/ingest_request"
    },
    {
      "$ref": "#/$defs/ingest_response"
    },
    {
      "$ref": "#/$defs/wake_request"
    },
    {
      "$ref": "#/$defs/wake_response"
    },
    {
      "$ref": "#/$defs/ask_request"
    },
    {
      "$ref": "#/$defs/ask_response"
    },
    {
      "$ref": "#/$defs/goto_request"
    },
    {
      "$ref": "#/$defs/goto_response"
    },
    {
      "$ref": "#/$defs/near_request"
    },
    {
      "$ref": "#/$defs/near_response"
    },
    {
      "$ref": "#/$defs/rewind_request"
    },
    {
      "$ref": "#/$defs/rewind_response"
    },
    {
      "$ref": "#/$defs/forward_request"
    },
    {
      "$ref": "#/$defs/forward_response"
    },
    {
      "$ref": "#/$defs/trace_request"
    },
    {
      "$ref": "#/$defs/trace_response"
    },
    {
      "$ref": "#/$defs/inspect_request"
    },
    {
      "$ref": "#/$defs/inspect_response"
    }
  ],
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "date_time": {
      "type": "string",
      "format": "date-time"
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "semantic_class": {
      "type": "string",
      "enum": [
        "structural",
        "causal",
        "motivational",
        "procedural",
        "evidential",
        "constraint"
      ]
    },
    "answer_policy": {
      "type": "string",
      "enum": [
        "evidence_or_unknown",
        "show_conflicts",
        "best_effort"
      ]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_kind",
        "source_agent",
        "observed_at"
      ],
      "properties": {
        "source_kind": {
          "type": "string",
          "enum": [
            "human",
            "agent",
            "projection",
            "derived"
          ]
        },
        "source_agent": {
          "$ref": "#/$defs/non_empty_string"
        },
        "observed_at": {
          "$ref": "#/$defs/date_time"
        },
        "correlation_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "causation_id": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "title": {
          "$ref": "#/$defs/non_empty_string"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "temporal_coordinate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimension",
        "scope_id"
      ],
      "properties": {
        "dimension": {
          "$ref": "#/$defs/non_empty_string"
        },
        "scope_id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "occurred_at": {
          "$ref": "#/$defs/date_time"
        },
        "observed_at": {
          "$ref": "#/$defs/date_time"
        },
        "ingested_at": {
          "$ref": "#/$defs/date_time"
        },
        "valid_from": {
          "$ref": "#/$defs/date_time"
        },
        "valid_until": {
          "$ref": "#/$defs/date_time"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "text",
        "coordinates"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/temporal_coordinate"
          }
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "relation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to",
        "rel",
        "class"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to": {
          "$ref": "#/$defs/non_empty_string"
        },
        "rel": {
          "$ref": "#/$defs/non_empty_string"
        },
        "class": {
          "$ref": "#/$defs/semantic_class"
        },
        "why": {
          "$ref": "#/$defs/non_empty_string"
        },
        "evidence": {
          "$ref": "#/$defs/non_empty_string"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "class": {
                "const": "structural"
              }
            },
            "required": [
              "class"
            ]
          },
          "then": true,
          "else": {
            "required": [
              "confidence"
            ],
            "anyOf": [
              {
                "required": [
                  "why"
                ]
              },
              {
                "required": [
                  "evidence"
                ]
              }
            ]
          }
        }
      ]
    },
    "evidence_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "text"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/non_empty_string"
        },
        "supports": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source": {
          "$ref": "#/$defs/non_empty_string"
        },
        "time": {
          "$ref": "#/$defs/date_time"
        },
        "metadata": {
          "$ref": "#/$defs/metadata"
        }
      }
    },
    "memory": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "dimensions",
        "entries"
      ],
      "properties": {
        "dimensions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dimension"
          }
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entry"
          }
        },
        "relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_item"
          }
        }
      }
    },
    "accepted_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "entries",
        "relations",
        "evidence"
      ],
      "properties": {
        "entries": {
          "type": "integer",
          "minimum": 0
        },
        "relations": {
          "type": "integer",
          "minimum": 0
        },
        "evidence": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "warning_list": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/non_empty_string"
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "tokens": {
          "type": "integer",
          "minimum": 1
        },
        "detail": {
          "type": "string",
          "enum": [
            "compact",
            "balanced",
            "full"
          ]
        }
      }
    },
    "dimension_selection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "all",
            "only",
            "except"
          ]
        },
        "include": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "exclude": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        }
      }
    },
    "temporal_cursor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "time": {
          "$ref": "#/$defs/date_time"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "ref"
          ]
        },
        {
          "required": [
            "time"
          ]
        },
        {
          "required": [
            "sequence"
          ]
        }
      ]
    },
    "temporal_limit": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "entries": {
          "type": "integer",
          "minimum": 1
        },
        "tokens": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "temporal_window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "before_entries": {
          "type": "integer",
          "minimum": 1
        },
        "after_entries": {
          "type": "integer",
          "minimum": 1
        },
        "before_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "after_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "temporal_include": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "evidence": {
          "type": "boolean"
        },
        "relations": {
          "type": "boolean"
        },
        "raw_refs": {
          "type": "boolean"
        }
      }
    },
    "temporal_move_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "from"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "from": {
          "$ref": "#/$defs/temporal_cursor"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        },
        "limit": {
          "$ref": "#/$defs/temporal_limit"
        },
        "include": {
          "$ref": "#/$defs/temporal_include"
        }
      }
    },
    "temporal_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ref",
        "text",
        "coordinates"
      ],
      "properties": {
        "ref": {
          "$ref": "#/$defs/non_empty_string"
        },
        "text": {
          "$ref": "#/$defs/non_empty_string"
        },
        "position": {
          "type": "string",
          "enum": [
            "before",
            "at",
            "after",
            "near"
          ]
        },
        "coordinates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/temporal_coordinate"
          }
        }
      }
    },
    "temporal_move_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "temporal",
        "coverage",
        "entries",
        "proof",
        "warnings"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "temporal": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "direction"
          ],
          "properties": {
            "direction": {
              "type": "string",
              "enum": [
                "goto",
                "near",
                "rewind",
                "forward"
              ]
            },
            "at": {
              "$ref": "#/$defs/temporal_cursor"
            },
            "around": {
              "$ref": "#/$defs/temporal_cursor"
            },
            "from": {
              "$ref": "#/$defs/temporal_cursor"
            },
            "window": {
              "$ref": "#/$defs/temporal_window"
            }
          }
        },
        "coverage": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requested",
            "included",
            "missing"
          ],
          "properties": {
            "requested": {
              "$ref": "#/$defs/dimension_selection"
            },
            "included": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "missing": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        },
        "entries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/temporal_entry"
          }
        },
        "proof": {
          "$ref": "#/$defs/proof"
        },
        "warnings": {
          "$ref": "#/$defs/warning_list"
        }
      }
    },
    "goto_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "at"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "at": {
          "$ref": "#/$defs/temporal_cursor"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        },
        "include": {
          "$ref": "#/$defs/temporal_include"
        }
      }
    },
    "goto_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "near_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "around"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "around": {
          "$ref": "#/$defs/temporal_cursor"
        },
        "window": {
          "$ref": "#/$defs/temporal_window"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        },
        "include": {
          "$ref": "#/$defs/temporal_include"
        }
      }
    },
    "near_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "rewind_request": {
      "$ref": "#/$defs/temporal_move_request"
    },
    "rewind_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "forward_request": {
      "$ref": "#/$defs/temporal_move_request"
    },
    "forward_response": {
      "$ref": "#/$defs/temporal_move_response"
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "confidence"
      ],
      "properties": {
        "path": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_item"
          }
        },
        "conflicts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "missing": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      }
    },
    "ingest_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "memory",
        "idempotency_key"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "memory": {
          "$ref": "#/$defs/memory"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        },
        "idempotency_key": {
          "$ref": "#/$defs/non_empty_string"
        },
        "dry_run": {
          "type": "boolean"
        }
      }
    },
    "ingest_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "memory",
        "warnings"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "memory": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "about",
            "memory_id",
            "accepted",
            "read_after_write_ready"
          ],
          "properties": {
            "about": {
              "$ref": "#/$defs/non_empty_string"
            },
            "memory_id": {
              "$ref": "#/$defs/non_empty_string"
            },
            "accepted": {
              "$ref": "#/$defs/accepted_counts"
            },
            "read_after_write_ready": {
              "type": "boolean"
            }
          }
        },
        "warnings": {
          "$ref": "#/$defs/warning_list"
        }
      }
    },
    "wake_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "role": {
          "$ref": "#/$defs/non_empty_string"
        },
        "intent": {
          "$ref": "#/$defs/non_empty_string"
        },
        "budget": {
          "$ref": "#/$defs/budget"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        }
      }
    },
    "wake_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "wake",
        "proof",
        "warnings"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "wake": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "objective",
            "current_state",
            "causal_spine",
            "open_loops",
            "next_actions",
            "guardrails"
          ],
          "properties": {
            "objective": {
              "$ref": "#/$defs/non_empty_string"
            },
            "current_state": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "causal_spine": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "claim",
                  "because"
                ],
                "properties": {
                  "claim": {
                    "$ref": "#/$defs/non_empty_string"
                  },
                  "because": {
                    "$ref": "#/$defs/non_empty_string"
                  },
                  "evidence_ref": {
                    "$ref": "#/$defs/non_empty_string"
                  }
                }
              }
            },
            "open_loops": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "next_actions": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            },
            "guardrails": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        },
        "proof": {
          "$ref": "#/$defs/proof"
        },
        "warnings": {
          "$ref": "#/$defs/warning_list"
        }
      }
    },
    "ask_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "about",
        "question"
      ],
      "properties": {
        "about": {
          "$ref": "#/$defs/non_empty_string"
        },
        "question": {
          "$ref": "#/$defs/non_empty_string"
        },
        "answer_policy": {
          "$ref": "#/$defs/answer_policy"
        },
        "prefer": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "time": {
              "type": "string",
              "enum": [
                "latest",
                "earliest",
                "as_of"
              ]
            },
            "relations": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        },
        "budget": {
          "$ref": "#/$defs/budget"
        },
        "dimensions": {
          "$ref": "#/$defs/dimension_selection"
        }
      }
    },
    "ask_response": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "answer",
        "because",
        "proof",
        "warnings"
      ],
      "properties": {
        "summary": {
          "$ref": "#/$defs/non_empty_string"
        },
        "answer": {
          "type": [
            "string",
            "null"
          ]
        },
        "because": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "claim",
              "evidence",
              "ref"
            ],
            "properties": {
              "claim": {
                "$ref": "#/$defs/non_empty_string"
              },
              "evidence": {
                "$ref": "#/$defs/non_empty_string"
              },
              "ref": {
                "$ref": "#/$defs/non_empty_string"
              }
            }
          }
        },
        "proof": {
          "$ref": "#/$defs/proof"
        },
        "warnings": {
          "$ref": "#/$defs/warning_list"
        }
      }
    },
    "trace_request": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "from",
        "to"
      ],
      "properties": {
        "from": {
          "$ref": "#/$defs/non_empty_string"
        },
        "to": {
          "$ref": "#/$defs/non_empty_string"
        },
        "goal": {
          "$ref": "#/$defs/non_empty_string"
        },
        "include": {
          "type": "object",
